{
  "schema_version": "1",
  "framework_version": "v1",
  "source_mode": "folder",
  "folder_root": ".ai/AI-LTC",
  "repo_url": "https://github.com/Hope2333/AI-LTC",
  "repo_ref": "main",
  "project_state": "greenfield",
  "working_language": "English",
  "human_summary_language": "Chinese",
  "human_input_language_policy": "auto-detect",
  "skeleton_status": "copied",
  "default_operator_model": "qwen-3.5-plus",
  "default_operator_prompt": "qwen-generalist-autopilot.prompt.md",
  "supervisory_prompt": "qwen-supervisory-generalist.prompt.md",
  "architect_prompt": "gpt-bootstrap-architect.prompt.md",
  "auditor_prompt": "gpt-optimizer-auditor.prompt.md",
  "experimental_mode": {
    "enabled": true,
    "operator_model": "qwen-3.6-plus-free",
    "allow_gpt_prompts": true,
    "aggressive_mcp": true,
    "max_parallel_subagents": 5,
    "window_start": "2026-03-30",
    "window_end": ""
  },
  "multi_session": {
    "enabled": true,
    "max_concurrent": 3,
    "session_timeout_minutes": 10,
    "retry_limit": 1,
    "cleanup_after_merge": true,
    "keep_last_n_per_role": 3
  },
  "observability": {
    "logging_enabled": true,
    "log_level": "info",
    "log_dir": ".ai/logs",
    "snapshot_on_phase_change": true,
    "snapshot_dir": ".ai/history/snapshots",
    "max_log_lines": 10000,
    "metrics": {
      "track_task_success_rate": true,
      "track_retry_count": true,
      "track_token_saved": false,
      "track_escalation_frequency": true
    }
  }
}
